---
import About from "../components/About.astro";
import Agenda from "../components/Agenda.astro";
import Benefits from "../components/Benefits";
import FAQ from "../components/FAQ.astro";
import Gallery from "../components/Gallery";
import Header from "../components/Header.astro";
import PrizePool from "../components/PrizePool.astro";
import Sponsors from "../components/Sponsors";
import Timeline from "../components/Timeline";
import Welcome from "../components/Welcome.astro";
import { getLangFromCookie } from "../i18n/utils";
import Layout from "../layouts/Layout.astro";

const lang = getLangFromCookie(Astro.cookies);
---

<Layout title="WISH">
  <Header />
  <Welcome />
  <About />
  <PrizePool />
  <Benefits lang={lang} client:load />

  <Timeline lang={lang} client:load />
  <Sponsors />
  <Agenda />
  <Gallery lang={lang} client:load />
  <FAQ />
</Layout>
