---
import "../styles/global.css";
import { getLangFromCookie } from "../i18n/utils";

const lang = getLangFromCookie(Astro.cookies);
const {
  title,
  description = "Women in STEM Hackathon organised by NU ACM-W SC. A hackathon focuses on empowering girls in Data Science, AI & ML.",
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={lang === "kz" ? "kk" : lang} data-locale={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL("/favicon.svg", Astro.site)} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
    <script is:inline>
      (function () {
        var isTg =
          typeof window.TelegramWebview !== "undefined" ||
          typeof window.TelegramWebviewProxy !== "undefined";
        if (!isTg) return;

        document.addEventListener("click", function (e) {
          var el = e.target;
          while (el && el.tagName !== "A") el = el.parentElement;
          if (!el) return;

          var href = el.getAttribute("href");
          if (
            !href ||
            href.charAt(0) === "#" ||
            /^https?:\/\/|^\/\//.test(href)
          )
            return;

          e.preventDefault();
          var f = document.createElement("form");
          f.method = "GET";
          f.action = href;
          f.style.display = "none";
          document.body.appendChild(f);
          f.submit();
        });
      })();
    </script>
  </head>
  <body class="flex min-h-screen flex-col">
    <main class="flex-grow">
      <slot name="header" />
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
