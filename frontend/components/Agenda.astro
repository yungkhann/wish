---
import { getLangFromCookie, useTranslations } from "../i18n/utils";

const lang = getLangFromCookie(Astro.cookies);
const t = useTranslations(lang);

const day1 = [
  { time: "9:00", title: t("schedule.d1_t1") },
  { time: "10:00", title: t("schedule.d1_t2") },
  { time: "11:00", title: t("schedule.d1_t3") },
  { time: "12:00", title: t("schedule.d1_t4") },
  { time: "14:00", title: t("schedule.d1_t5") },
];

const day2 = [
  { time: "12:00", title: t("schedule.d2_t1") },
  { time: "12:30", title: t("schedule.d2_t2") },
  { time: "13:30", title: t("schedule.d2_t3") },
  { time: "18:30", title: t("schedule.d2_t4") },
];
---

<section class="bg-black pb-12 text-white">
  <div
    class="mx-auto grid max-w-7xl grid-cols-1 gap-24 md:grid-cols-2 md:gap-12"
  >
    <div class="relative">
      <h3
        class="mb-10 text-center font-['Marcellus'] text-xl font-bold text-white/90 uppercase sm:mb-14 sm:text-2xl md:mb-16 md:text-4xl"
      >
        {t("schedule.day1")}
      </h3>

      <div
        class="absolute top-20 bottom-0 left-1/2 w-[2px] -translate-x-1/2 bg-white/40"
        aria-hidden="true"
      >
      </div>

      <div class="flex flex-col gap-8 sm:gap-12 md:gap-16">
        {
          day1.map((event, idx) => (
            <div class="relative grid grid-cols-[1fr_auto_1fr] items-center gap-4 md:gap-10">
              <div
                class:list={[
                  "text-right",
                  idx % 2 !== 0 && "invisible opacity-0 md:block",
                ]}
              >
                <p class="font-['Marcellus'] text-sm opacity-70 sm:text-base lg:text-lg">
                  {event.time}
                </p>
                <h4 class="mt-1 font-['Marcellus'] text-sm leading-tight sm:text-base lg:text-xl xl:text-2xl">
                  {event.title}
                </h4>
              </div>

              <div class="relative z-10 flex size-6 items-center justify-center">
                <div class="size-3 rounded-full bg-[#A855F7] shadow-[0_0_15px_#A855F7]" />
                <div class="absolute size-8 animate-pulse rounded-full bg-[#A855F7]/20 blur-md" />
              </div>

              <div
                class:list={[
                  "text-left",
                  idx % 2 === 0 && "invisible opacity-0 md:block",
                ]}
              >
                <p class="font-['Marcellus'] text-sm opacity-70 sm:text-base lg:text-lg">
                  {event.time}
                </p>
                <h4 class="mt-1 font-['Marcellus'] text-sm leading-tight sm:text-base lg:text-xl xl:text-2xl">
                  {event.title}
                </h4>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="relative">
      <h3
        class="mb-10 text-center font-['Marcellus'] text-xl font-bold text-white/90 uppercase sm:mb-14 sm:text-2xl md:mb-16 md:text-4xl"
      >
        {t("schedule.day2")}
      </h3>

      <div
        class="absolute top-20 bottom-0 left-1/2 w-[2px] -translate-x-1/2 bg-white/40"
        aria-hidden="true"
      >
      </div>

      <div class="flex flex-col gap-8 sm:gap-12 md:gap-16">
        {
          day2.map((event, idx) => (
            <div class="relative grid grid-cols-[1fr_auto_1fr] items-center gap-4 md:gap-10">
              <div
                class:list={[
                  "text-right",
                  idx % 2 !== 0 && "invisible opacity-0 md:block",
                ]}
              >
                <p class="font-['Marcellus'] text-sm opacity-70 sm:text-base lg:text-lg">
                  {event.time}
                </p>
                <h4 class="mt-1 font-['Marcellus'] text-sm leading-tight sm:text-base lg:text-xl xl:text-2xl">
                  {event.title}
                </h4>
              </div>

              <div class="relative z-10 flex size-6 items-center justify-center">
                <div class="size-3 rounded-full bg-[#A855F7] shadow-[0_0_15px_#A855F7]" />
                <div class="absolute size-8 animate-pulse rounded-full bg-[#A855F7]/20 blur-md" />
              </div>

              <div
                class:list={[
                  "text-left",
                  idx % 2 === 0 && "invisible opacity-0 md:block",
                ]}
              >
                <p class="font-['Marcellus'] text-sm opacity-70 sm:text-base lg:text-lg">
                  {event.time}
                </p>
                <h4 class="mt-1 font-['Marcellus'] text-sm leading-tight sm:text-base lg:text-xl xl:text-2xl">
                  {event.title}
                </h4>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <div
    class="mt-8 flex flex-row items-start justify-center gap-2 text-left text-white/80 sm:items-center sm:justify-center sm:text-right"
  >
    <span
      class="pt-[0.1rem] font-['Marcellus'] text-2xl leading-none text-[#B743FF] drop-shadow-[0_0_8px_rgba(183,67,255,0.8)] sm:pt-0"
      >*</span
    >
    <span
      class="font-['Marcellus'] text-xs font-normal tracking-wide lowercase sm:text-sm lg:text-base"
      >{t("schedule.disclaimer")}</span
    >
  </div>
</section>
